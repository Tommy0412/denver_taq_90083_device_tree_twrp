DEVICE_PATH := device/denver/TAQ90

# For building with minimal manifest
ALLOW_MISSING_DEPENDENCIES := true

# Architecture
TARGET_ARCH := arm
TARGET_ARCH_VARIANT := armv7-a-neon
TARGET_CPU_ABI := armeabi-v7a
TARGET_CPU_ABI2 := 
TARGET_CPU_VARIANT := cortex-a7
TARGET_CPU_VARIANT_RUNTIME := cortex-a7
# Bootloader
TARGET_BOOTLOADER_BOARD_NAME := rk30board
TARGET_NO_BOOTLOADER := true

# Display
TARGET_SCREEN_DENSITY := 160

# Kernel
BOARD_BOOTIMG_HEADER_VERSION := 0
BOARD_KERNEL_BASE := 0x10000000
BOARD_KERNEL_CMDLINE := earlycon=uart8250,mmio32,0x20068000 console=ttyFIQ0 androidboot.baseband=N/A androidboot.veritymode=permissive androidboot.hardware=rk30board androidboot.console=ttyFIQ0 mtdparts=rk29xxnand:0x00002000@0x00002000(uboot),0x00002000@0x00004000(trust),0x00002000@0x00006000(misc),0x00008000@0x00008000(resource),0x00010000@0x00010000(kernel),0x00010000@0x00020000(boot),0x00020000@0x00030000(recovery),0x00038000@0x00050000(backup),0x00002000@0x0088000(security),0x0080000@0x0008a000(cache),0x00300000@0x0010a000(system),0x00008000@0x0040a000(metadata),0x00040000@0x00412000(vendor),0x00060000@0x00452000(oem),0x00000400@0x004B2000(frp),-@0x004B2400(userdata) storagemedia=emmc uboot_logo=0x02000000@0x9dc00000 SecureBootCheckOk=0 androidboot.selinux=permissive
TARGET_BUILD_VARIANT := userdebug
BOARD_HAS_NO_SELINUX := true
BOARD_KERNEL_PAGESIZE := 2048
BOARD_KERNEL_OFFSET := 0x00008000
BOARD_RAMDISK_OFFSET := 0x01000000
BOARD_KERNEL_TAGS_OFFSET := 0x00000100
BOARD_KERNEL_IMAGE_NAME := Image
BOARD_INCLUDE_DTB_IN_BOOTIMG := false
TARGET_FORCE_PREBUILT_KERNEL := true
TARGET_PREBUILT_DTB := $(DEVICE_PATH)/prebuilt/dt.img
BOARD_MKBOOTIMG_ARGS := --dt $(TARGET_PREBUILT_DTB) --kernel_offset 0x00008000 --ramdisk_offset 0x01000000 --tags_offset 0x00000100 --os_version 8.1.0 --os_patch_level 2019-09
TARGET_PREBUILT_KERNEL := $(DEVICE_PATH)/prebuilt/kernel
BOARD_BUILD_RESOURCE_IMAGE := false
#TARGET_PREBUILT_RESOURCE := $(DEVICE_PATH)/prebuilt/resource.img
# Partitions
BOARD_BOOTIMAGE_PARTITION_SIZE := 33554432 
BOARD_RECOVERYIMAGE_PARTITION_SIZE := 67108864 
BOARD_FLASH_BLOCK_SIZE := 131072
BOARD_HAS_LARGE_FILESYSTEM := true
BOARD_SYSTEMIMAGE_PARTITION_TYPE := ext4
BOARD_USERDATAIMAGE_FILE_SYSTEM_TYPE := f2fs
BOARD_VENDORIMAGE_FILE_SYSTEM_TYPE := ext4
TARGET_COPY_OUT_VENDOR := vendor

# Platform
TARGET_BOARD_PLATFORM := rk3126c

# Recovery
TARGET_USERIMAGES_USE_EXT4 := true
TARGET_USERIMAGES_USE_F2FS := true
TW_INCLUDE_F2FS := true
PRODUCT_PACKAGES += \
    fsck.f2fs \
    mkfs.f2fs
TW_THEME := landscape_mdpi
TARGET_SCREEN_WIDTH := 1024
TARGET_SCREEN_HEIGHT := 600
TW_EXTRA_LANGUAGES := false
TW_INPUT_BLACKLIST := "hbtp_vm"
TW_USE_TOOLBOX := true
# Hack: prevent anti rollback
PLATFORM_SECURITY_PATCH := 2019-09-05
VENDOR_SECURITY_PATCH := 2019-09-05
PLATFORM_VERSION := 8.1.0
PRODUCT_PLATFORM_VERSION := 8.1.0
BOARD_RAMDISK_COMPRESS := gzip
#LZMA_RAMDISK := true
TW_EXCLUDE_APAT := true
TW_EXCLUDE_ENCRYPT := true
TW_EXCLUDE_SUPERSU := true
TW_IGNORE_MISC_WIPE_DATA := true
TW_EXCLUDE_DEFAULT_USB_INIT := false
TW_INCLUDE_CRYPTO := false
TW_INCLUDE_LIBRESETPROP := true
TW_EXCLUDE_BASH := true
TW_EXCLUDE_NANO := true
TW_EXCLUDE_LPDUMP := true
TW_EXCLUDE_ENCRYPTED_BACKUP := true
DISABLE_VUSE := true
TW_EXCLUDE_NTP := true
TW_EXCLUDE_MTP := true
TW_NO_RADIO_COMM := true
BOARD_HAS_FLIPPED_SCREEN := false
TARGET_RECOVERY_OVERSCAN_PERCENT := 0
TW_USE_MODEL_HARDWARE := false
TW_SCREEN_BLANK_ON_BOOT := false
TW_NO_SCREEN_TIMEOUT := true
TW_DEBUG := true
TW_INCLUDE_LOGCAT := true
TW_INCLUDE_CRASH_HANDLER := true
RECOVERY_GRAPHICS_USE_GLES := false
RECOVERY_GRAPHICS_USE_FBDEV := true
RECOVERY_GRAPHICS_FORCE_USE_LINELENGTH := true
TARGET_RECOVERY_PIXEL_FORMAT := "RGBX_8888"
BOARD_RECOVERY_BLANK_ON_INIT := false
TW_ALLOW_SCREEN_BLANK := true
PRODUCT_EXTRA_RECOVERY_KEYS :=
TARGET_RECOVERY_FSTAB := device/denver/TAQ90/recovery/root/recovery.fstab
